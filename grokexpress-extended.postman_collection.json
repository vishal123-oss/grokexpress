              "path": ["v1", "products"]
            }
          },
          "response": []
        },
        {
          "name": "GET /v1/products/:id - Get product",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/products/10",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "products", "10"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "9. Combined Features",
      "description": "Test features working together",
      "item": [
        {
          "name": "POST /v1/users with CORS + body + rate limit",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Origin", "value": "https://example.com"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"New User\",\n  \"email\": \"new@example.com\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/users",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "users"]
            }
          },
          "response": []
        },
        {
          "name": "POST /body/form with CORS origin",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Origin", "value": "https://app.example.com"},
              {"key": "Content-Type", "value": "application/x-www-form-urlencoded"}
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {"key": "name", "value": "Cross Origin User"},
                {"key": "email", "value": "cross@example.com"}
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/body/form",
              "host": ["{{baseUrl}}"],
              "path": ["body", "form"]
            }
          },
          "response": []
        }
      ]
    }
  ]
}
